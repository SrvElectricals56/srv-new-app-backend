NODE_ENV=production
HOST=0.0.0.0
PORT=3001

# DigitalOcean Managed PostgreSQL. Prefer the private VPC hostname.
DB_HOST=
DB_PORT=25060
DB_USERNAME=doadmin
DB_PASSWORD=
DB_DATABASE=srv_db
DB_SSL=true
DB_SSL_REJECT_UNAUTHORIZED=true
DB_SSL_CA_PATH=/run/secrets/managed-postgres-ca.crt
DB_SYNCHRONIZE=false
DB_LOGGING=false
DB_MIGRATIONS_RUN=false

JWT_SECRET=
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=
JWT_REFRESH_EXPIRES_IN=30d

CORS_ORIGIN=https://admin.srvelectricals.in
CORS_CREDENTIALS=true
API_PREFIX=api/v1
BODY_LIMIT=10mb
SWAGGER_ENABLED=false
THROTTLE_TTL=60
THROTTLE_LIMIT=100

RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
