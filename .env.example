# # Server
# NODE_ENV=development
# PORT=3001
# HOST=0.0.0.0

# # Local backend connects to Docker PostgreSQL exposed on localhost:5433.
# DB_HOST=localhost
# DB_PORT=5433
# DB_USERNAME=postgres
# DB_PASSWORD=4268
# DB_DATABASE=srv_admin

# # Keep this false when using the imported SQL dump.
# # The dump contains real legacy/current data and is normalized by docker/postgres/*.sql.
# DB_SYNCHRONIZE=false
# DB_LOGGING=false
# DB_SSL=false
# DB_SSL_REJECT_UNAUTHORIZED=true
# DB_MIGRATIONS_RUN=false

# # JWT
# JWT_SECRET=srv-admin-secret-key-2024
# JWT_EXPIRES_IN=7d
# JWT_REFRESH_SECRET=srv-admin-refresh-secret-2024
# JWT_REFRESH_EXPIRES_IN=30d

# # Explicitly set only when running `npm run seed`.
# DEFAULT_ADMIN_PASSWORD=

# # CORS
# CORS_ORIGIN=http://localhost:3000,http://127.0.0.1:3000,http://localhost:8081,http://127.0.0.1:8081
# CORS_CREDENTIALS=true

# # API
# API_PREFIX=api/v1
# BODY_LIMIT=10mb
# SWAGGER_ENABLED=true

# # Razorpay
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=
# RAZORPAY_WEBHOOK_SECRET=

# # Rate Limiting
# THROTTLE_TTL=60
# THROTTLE_LIMIT=100
